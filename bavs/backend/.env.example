# ================================================================
# Banking Automation & Verification Suite — Environment Variables
# Copy this file to .env and fill in the values marked CHANGE_ME.
# ================================================================

# --- Database (already correct for Docker, do not change) ---
DATABASE_URL=postgresql://bankuser:bankpassword@postgres:5432/bankkyc

# --- Auth: CHANGE_ME — make up any long random string ---
JWT_SECRET_KEY=CHANGE_ME_make_this_long_and_random_eg_abc123xyz456def789ghi
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis (already correct for Docker, do not change) ---
REDIS_URL=redis://redis:6379/0

# --- MinIO local storage (already correct, do not change) ---
# MinIO runs inside Docker — no card, no internet, no account needed.
# Dashboard to browse your files: http://localhost:9001
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=bankkyc-storage
R2_ENDPOINT_URL=http://minio:9000

# --- Groq API Key: CHANGE_ME ---
# Free at https://console.groq.com/keys (email signup only, no card)
GROQ_API_KEY=CHANGE_ME_paste_your_groq_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]
